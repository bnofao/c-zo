    "jiti": "catalog:common",
    "kysely": "catalog:common",
    "nodemailer": "catalog:",
    "pathe": "catalog:common",
    "pg": "catalog:common",
    "rate-limiter-flexible": "catalog:",
    "tinyglobby": "catalog:common",
    "zod": "catalog:common"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@testcontainers/postgresql": "catalog:dev",
    "@types/amqplib": "catalog:types",
    "@types/nodemailer": "catalog:types",
    "@types/pg": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "graphql": "catalog:common",
    "graphql-yoga": "catalog:common",
    "h3": "catalog:",
    "nitro": "catalog:dev",
