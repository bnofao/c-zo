  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --import ./src/register-otel.mjs --import tsx --watch src/main.ts",
    "start": "node --import ./src/register-otel.mjs --import tsx src/main.ts",
    "check-types": "pnpm tsc --noEmit",
